{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ZeroEye Build Diagnostic Schema",
  "description": "Schema for the build diagnostic metadata generated by the ZeroEye build script.",
  "type": "object",
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "commit": {
      "type": "string",
      "description": "The first 8 characters of the git commit hash."
    },
    "diagnostic_logd": {
      "type": "string",
      "description": "Path to the encrypted log file."
    },
    "diagnostic_logd_error": {
      "type": ["string", "null"]
    },
    "chunked": {
      "type": "boolean"
    },
    "chunk_size_bytes": {
      "type": ["integer", "null"]
    },
    "password": {
      "type": "string",
      "description": "Password for decrypting the log file."
    },
    "decrypt_command": {
      "type": "string"
    },
    "total_modules": {
      "type": "integer",
      "minimum": 0
    },
    "passed": {
      "type": "integer",
      "minimum": 0
    },
    "failed": {
      "type": "integer",
      "minimum": 0
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["PASS", "FAIL", "SKIP", "UNKNOWN"] },
          "elapsed_seconds": { "type": "integer", "minimum": 0 },
          "artifact": { "type": ["string", "null"] },
          "output": { "type": "string" }
        },
        "required": ["name", "status"]
      }
    },
    "pr_note": {
      "type": "string"
    }
  },
  "required": [
    "generated_at",
    "commit",
    "diagnostic_logd",
    "password",
    "total_modules",
    "modules"
  ]
}
